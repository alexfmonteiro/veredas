# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it contains secrets.

# Cloudflare
cloudflare_api_token  = ""
cloudflare_account_id = ""
r2_bucket_name        = "br-economic-pulse-data"

# Neon
neon_api_key      = ""
neon_project_name = "br-economic-pulse"
neon_database_name = "br_economic_pulse"
neon_region       = "aws-us-east-1"

# Upstash
upstash_email  = ""
upstash_api_key = ""
upstash_region = "us-east-1"

# Sentry
sentry_token        = ""
sentry_organization = ""

# General
environment = "production"
